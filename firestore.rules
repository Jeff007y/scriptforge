rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string && data.email.size() <= 200
        && data.createdAt is string
        && (data.get('displayName', '') is string)
        && (data.get('photoURL', '') is string)
        && (data.get('settings', {}) is map);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['ownerId', 'title', 'createdAt', 'updatedAt'])
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && (data.get('logline', '') is string)
        && data.createdAt is string
        && data.updatedAt is string;
    }

    function isValidScriptBlock(data) {
      return data.keys().hasAll(['projectId', 'type', 'content', 'order'])
        && data.projectId is string && data.projectId.size() <= 128
        && data.type is string && data.type.size() <= 50
        && data.content is string && data.content.size() <= 50000
        && data.order is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId
                    && isValidId(userId)
                    && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'settings']);
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      match /blocks/{blockId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
      match /characters/{characterId} {
        allow read, create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
      match /beats/{beatId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
      match /storyboard/{panelId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
      match /bible_entries/{entryId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
